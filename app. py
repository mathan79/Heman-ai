import os
from flask import Flask, jsonify
from flask_cors import CORS  # underscore fixed

app = Flask(__name__)
CORS(app)

@app.route("/")
def home():
    return "MATHAN AI HEMAN - LIVE!"

@app.route("/ping")
def ping():
    return jsonify({"status": "OK", "time": "HEMAN Live"})

@app.route("/dashboard")
def dashboard():
    return "HEMAN Dashboard Coming Soon!"

if __name__ == "__main__":
    port = int(os.environ.get("PORT", 5000))
    app.run(host="0.0.0.0", port=port, debug=False)